# For LOCAL development with Hardhat node (npx hardhat node):
# These defaults work out of the box. Just copy this file to .env.
VITE_APPCHAIN_ID=trying
VITE_NATIVE_DENOM=GAS
VITE_NATIVE_SYMBOL=GAS
VITE_NATIVE_DECIMALS=18
VITE_JSON_RPC_URL=http://localhost:8545

# For REAL Initia appchain deployment, update VITE_APPCHAIN_ID to your chain ID
# and VITE_JSON_RPC_URL if the RPC is on a different host/port.
