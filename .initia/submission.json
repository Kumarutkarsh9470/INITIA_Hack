{
  "project_name": "PixelVault",
  "description": "Full-stack on-chain gaming platform on Initia MiniEVM with ERC-6551 Token Bound Accounts, dual-game mechanics, integrated AMM DEX, P2P marketplace, meta-transaction gas paymaster, and achievement system.",
  "category": "gaming",
  "chain": "minievm",
  "contracts": {
    "PXLToken": "0x9317c2bc53aa77A52dEFfd06b62e41bFa6b64cc4",
    "PlayerProfile": "0xf9Ae3a14B2734A48DE48FD665119c05cc82f9997",
    "ERC6551Registry": "0x8e09fB32f113c04D4E67DeD9836F81Ae24b56731",
    "ERC6551Account": "0x720AD31670bac31b8AeBB4C390189486e6193669",
    "GameRegistry": "0xa1dB25a15dA4841C6D2Ae85f1D12F9B12e1cBF21",
    "PixelVaultDEX": "0x117d29c5a273b80e86BdE477ff53C5861a73BD7d",
    "Marketplace": "0x36a9A7c2a770943F6Bd5056d9da1Da8Fe406C000",
    "DungeonDrops": "0x7285b97D6FdCc3716C198d54A2842e5eb5a4D1F8",
    "HarvestField": "0xFf1ab7297E4E800f0BB4F804Cd4F42441fc6a338",
    "AchievementBadge": "0x9b519086532e3EA760f818d3440f7014e3070244",
    "GasPaymaster": "0xb45a24715BEE2B761167b46aFB69A4A9822bee6e",
    "CommonRelic": "0x4f922647E0aaC41D6B4C451A44D7B0f6409dB99a"
  },
  "frontend": {
    "framework": "React + TypeScript + Vite",
    "url": "http://localhost:5173"
  },
  "build": {
    "install": "npm install && cd frontend && npm install",
    "deploy": "npx hardhat run scripts/deploy.ts --network minievm",
    "wire": "npx hardhat run scripts/wire.ts --network minievm",
    "seed_dex": "npx hardhat run scripts/seed-dex.ts --network minievm",
    "seed_marketplace": "npx hardhat run scripts/seed-marketplace.ts --network minievm",
    "frontend_dev": "cd frontend && npm run dev"
  },
  "features": [
    "ERC-6551 Token Bound Accounts for player profiles",
    "Dual-game mechanics (Dungeon Drops + Harvest Field)",
    "Constant-product AMM DEX with 0.3% swap fee",
    "P2P ERC-1155 item marketplace with 2.5% protocol fee",
    "GasPaymaster meta-transactions (ERC-2771 forwarding)",
    "On-chain achievement badges + reputation system",
    "Auto-faucet on profile creation",
    "Session key support via InterwovenKit"
  ]
}
